{
  "manifest_version": 3,
  "name": "Language Agent",
  "version": "0.6.0",
  "description": "多语言实时流式语音识别+翻译 - Vosk本地识别",
  "permissions": ["activeTab", "tabCapture", "storage", "offscreen"],
  "host_permissions": ["http://localhost:*/", "ws://localhost:*/", "https://api.dictionaryapi.dev/", "https://*.wiktionary.org/"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Language Agent"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "offscreen": {
    "document": "offscreen.html"
  },
  "icons": {}
}
